{
  "name": "xeno-crm",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "dev:web": "turbo run dev --filter=@xeno/web",
    "dev:crm-api": "turbo run dev --filter=@xeno/crm-api",
    "dev:channel-stub": "turbo run dev --filter=@xeno/channel-stub",
    "db:migrate": "pnpm --filter @xeno/crm-api db:migrate",
    "db:seed": "pnpm --filter @xeno/crm-api db:seed",
    "db:studio": "pnpm --filter @xeno/crm-api db:studio",
    "db:generate": "pnpm --filter @xeno/crm-api db:generate",
    "reconcile": "pnpm --filter @xeno/crm-api reconcile"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
