# ── Database ───────────────────────────────────────────────────────────────────────────
# Local: a direct Neon (or local Postgres) connection string.
# Production (Render): use the Neon POOLED connection string (the "-pooler" host) and append
#   ?sslmode=require&pgbouncer=true&connection_limit=5
# pgbouncer=true disables prepared statements (required behind Neon's PgBouncer pooler).
DATABASE_URL=

# OPTIONAL — only read by the deploy build's migrate+seed step (see render.yaml), never at
# runtime. Set to the Neon DIRECT (non-pooled) connection string so `prisma migrate deploy`
# and the seed avoid PgBouncer advisory-lock / prepared-statement issues. Unset locally.
# MIGRATE_DATABASE_URL=

# ── Service URLs ───────────────────────────────────────────────────────────────────────
CHANNEL_STUB_URL=http://localhost:3002
PUBLIC_BASE_URL=http://localhost:3001

# CORS allow-origin for the web app. Local default is http://localhost:3000.
# Production: set to the deployed Vercel origin, e.g. https://your-web.vercel.app
WEB_ORIGIN=http://localhost:3000

# ── Worker / queue knobs ───────────────────────────────────────────────────────────────
WORKER_CONCURRENCY=10
WORKER_MAX_ATTEMPTS=5
SEND_RATE_PER_SEC=50
# Reconciliation/completion sweep cadence in ms (defaults to 30000 if unset).
RECONCILE_INTERVAL_MS=30000

# PORT is injected by the host (Render sets it). Defaults to 3001 locally if unset.
# PORT=3001
