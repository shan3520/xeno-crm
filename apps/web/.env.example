# ── AI (Gemini via @ai-sdk/google — primary provider) ──────────────────────────────────
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_FAST=gemini-2.5-flash-lite

# ── AI provider fallback chain (lib/ai/providers.ts) ───────────────────────────────────
# Comma-separated try order for LLM providers. When a provider is rate-limited, unavailable,
# or too SLOW (per-provider timeout below), the SAME turn falls through to the next provider.
# Unset (or blank) = "groq,gemini". A provider whose API key is missing is silently skipped.
# REQUIREMENT: every model in the chain MUST support tool calling (function calling) —
# the console's segment/message/narrate tools depend on it.
#AI_PROVIDER_ORDER=groq,nvidia,gemini

# Per-provider response budget (ms) before failing over to the next provider. Default 22000.
#AI_PROVIDER_TIMEOUT_MS=22000

# Groq (free tier) — GROQ_MODEL must be tool-calling-capable.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# NVIDIA NIM (free tier, OpenAI-compatible) — NVIDIA_MODEL must be tool-calling-capable.
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# ── CRM API URL ────────────────────────────────────────────────────────────────────────
# Server-side calls (/api/chat -> crm-client.ts) use CRM_API_URL.
# Browser calls (dashboard analytics) use NEXT_PUBLIC_CRM_API_URL.
# Set BOTH to the same value. Production: the Render crm-api URL, e.g.
#   https://xeno-crm-api.onrender.com
CRM_API_URL=http://localhost:3001
NEXT_PUBLIC_CRM_API_URL=http://localhost:3001
